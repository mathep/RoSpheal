{
	"private": true,
	"sideEffects": false,
	"scripts": {
		"build": "bun i && bun ./scripts/build.ts",
		"redist": "bun i && bun ./scripts/buildRedistribution.ts",
		"get-src": "bun ./scripts/getSrc.ts",
		"get-i18n": "bun ./scripts/getCrowdinI18n.ts",
		"sign-amo": "bun ./scripts/signAMO.ts",
		"convert-crowdin-i18n": "bun ./scripts/convertCrowdinI18n.ts",
		"dev": "bun --watch ./scripts/dev.ts",
		"schema": "bun ts-json-schema-generator --path ./scripts/build/constants.ts --type Manifest --tsconfig ./tsconfig.json > ./src/types/schemas/manifest.json && bun ts-json-schema-generator --path ./scripts/build/constants.ts --type I18nFile --tsconfig ./tsconfig.json > ./src/types/schemas/i18nFile.json",
		"lint": "bun biome lint ./",
		"fmt": "bun biome format ./",
		"check": "bun biome check ./ --fix",
		"lc": "find . -name '*.ts*' -not -path './node_modules/*' -not -path './secret/*' -not -name '*.gen.*' | xargs wc -l"
	},
	"dependencies": {
		"@formatjs/intl-durationformat": "0.10.14",
